<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Color Palette ── -->
    <Color x:Key="BgDeep">#0D0D15</Color>
    <Color x:Key="BgCard">#15151F</Color>
    <Color x:Key="BgCardHover">#1E1E2A</Color>
    <Color x:Key="AccentRed">#FF4060</Color>
    <Color x:Key="AccentRedDim">#CC2040</Color>
    <Color x:Key="TextPrimary">#F0F0F8</Color>
    <Color x:Key="TextSecondary">#7070A0</Color>
    <Color x:Key="BorderSubtle">#2A2A3A</Color>
    <Color x:Key="GreenOk">#22DD66</Color>
    <Color x:Key="YellowWarn">#FFB830</Color>

    <SolidColorBrush x:Key="BgDeepBrush" Color="{StaticResource BgDeep}"/>
    <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}"/>
    <SolidColorBrush x:Key="AccentRedBrush" Color="{StaticResource AccentRed}"/>
    <SolidColorBrush x:Key="AccentRedDimBrush" Color="{StaticResource AccentRedDim}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtle}"/>
    <SolidColorBrush x:Key="GreenOkBrush" Color="{StaticResource GreenOk}"/>
    <SolidColorBrush x:Key="YellowWarnBrush" Color="{StaticResource YellowWarn}"/>
    <SolidColorBrush x:Key="TransparentBrush" Color="Transparent"/>

    <!-- ── Typography ── -->
    <FontFamily x:Key="AppFont">Segoe UI, Arial</FontFamily>

    <!-- ── Window Style ── -->
    <Style x:Key="DarkWindow" TargetType="Window">
        <Setter Property="Background" Value="{StaticResource BgDeepBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <!-- ── Card Border ── -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <!-- ── Primary Button ── -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF4060" Offset="0"/>
                    <GradientStop Color="#CC1830" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="18,9"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Opacity" Value="0.85"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Opacity" Value="0.7"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.35"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Secondary Button ── -->
    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Background" Value="#252535"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <!-- ── Ghost Button ── -->
    <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="Transparent"
                            BorderBrush="{StaticResource AccentRedBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#1AFF4060"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#2AFF4060"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.35"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Toggle / Checkbox style ── -->
    <Style x:Key="ToggleCheckbox" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <!-- ── ListBox for device list ── -->
    <Style x:Key="DeviceListBox" TargetType="ListBox">
        <Setter Property="Background" Value="#0D0D18"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
    </Style>

    <!-- ── ListBoxItem for device entries ── -->
    <Style x:Key="DeviceListItem" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bg"
                            Background="Transparent"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#1A3050FF"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#1AFF4060"/>
                            <Setter TargetName="Bg" Property="BorderBrush" Value="#33FF4060"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Section Label ── -->
    <Style x:Key="SectionLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- ── Big BPM label ── -->
    <Style x:Key="BigBpmLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="72"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI, Arial"/>
        <Setter Property="LineHeight" Value="72"/>
    </Style>

    <!-- ── Status bar text ── -->
    <Style x:Key="StatusText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontSize" Value="11.5"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <!-- ── URL copyable text ── -->
    <Style x:Key="UrlText" TargetType="TextBox">
        <Setter Property="Background" Value="#0D0D18"/>
        <Setter Property="Foreground" Value="#7090FF"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,5"/>
        <Setter Property="FontFamily" Value="Consolas, Courier New"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

</ResourceDictionary>
