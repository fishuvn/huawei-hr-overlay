<Window x:Class="HuaweiHROverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Huawei HR Overlay"
        Width="520" Height="680"
        MinWidth="460" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDeepBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI"
        ResizeMode="CanMinimize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header / BPM hero -->
            <RowDefinition Height="Auto"/>
            <!-- Device scanner -->
            <RowDefinition Height="*"/>
            <!-- Device list -->
            <RowDefinition Height="Auto"/>
            <!-- Action buttons -->
            <RowDefinition Height="Auto"/>
            <!-- OBS section -->
            <RowDefinition Height="Auto"/>
            <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ══════ HEADER / BPM HERO ══════ -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: title + BPM -->
                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="❤" Foreground="{StaticResource AccentRedBrush}" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Huawei HR Overlay" FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="OBS Heart Rate Overlay — powered by BLE" Style="{StaticResource StatusText}" Margin="0,0,0,16"/>

                    <!-- Live BPM display -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="LiveBpm" Text="--" Style="{StaticResource BigBpmLabel}"/>
                        <StackPanel Margin="10,12,0,0">
                            <TextBlock Text="BPM" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="ZoneLabel" Text="No signal" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Right: connection badge + sim toggle -->
                <StackPanel Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Right">
                    <Border x:Name="ConnBadge" CornerRadius="12" Padding="10,4" Background="#1A888888">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="ConnDot" Width="8" Height="8" Fill="#888888" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock x:Name="ConnText" Text="Disconnected" FontSize="11" FontWeight="SemiBold" Foreground="#888888" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <CheckBox x:Name="SimMode" Content="Simulate" Style="{StaticResource ToggleCheckbox}"
                              Margin="0,12,0,0" HorizontalAlignment="Right"
                              Checked="SimMode_Checked" Unchecked="SimMode_Unchecked"
                              ToolTip="Generate fake BPM values for testing without a watch"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════ DEVICE SCANNER ══════ -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="BLUETOOTH DEVICES" Style="{StaticResource SectionLabel}"/>
                    <TextBlock x:Name="ScanStatus" Text="Press Scan to discover HR devices…"
                               Style="{StaticResource StatusText}" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button x:Name="ScanButton" Content="▶  Scan" Style="{StaticResource SecondaryButton}"
                            Padding="14,7" Click="ScanButton_Click"/>
                    <Button x:Name="StopScanButton" Content="■  Stop" Style="{StaticResource GhostButton}"
                            Padding="14,7" Margin="8,0,0,0" Click="StopScanButton_Click" IsEnabled="False"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════ DEVICE LIST ══════ -->
        <Border Grid.Row="2" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="10" Margin="0,0,0,14" ClipToBounds="True">
            <ListBox x:Name="DeviceList"
                     Style="{StaticResource DeviceListBox}"
                     ItemContainerStyle="{StaticResource DeviceListItem}"
                     BorderThickness="0"
                     SelectionChanged="DeviceList_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding Id}" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="❤ HR" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource AccentRedBrush}" HorizontalAlignment="Right"/>
                                <TextBlock Text="{Binding RssiDisplay}" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- ══════ CONNECT / DISCONNECT BUTTONS ══════ -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,14">
            <Button x:Name="ConnectButton" Content="⚡  Connect" Style="{StaticResource PrimaryButton}"
                    IsEnabled="False" Click="ConnectButton_Click"/>
            <Button x:Name="DisconnectButton" Content="✕  Disconnect" Style="{StaticResource GhostButton}"
                    Margin="10,0,0,0" IsEnabled="False" Click="DisconnectButton_Click"/>
        </StackPanel>

        <!-- ══════ OBS SECTION ══════ -->
        <Border Grid.Row="4" Style="{StaticResource Card}" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="OBS BROWSER SOURCE" Style="{StaticResource SectionLabel}"/>
                <TextBlock Text="Add a Browser Source in OBS and paste this URL:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="OverlayUrlBox" Style="{StaticResource UrlText}" Text="http://localhost:8764/"/>
                    <Button Grid.Column="1" Content="Copy" Style="{StaticResource SecondaryButton}"
                            Padding="12,5" Margin="8,0,0,0" Click="CopyUrl_Click"/>
                </Grid>

                <StackPanel Orientation="Horizontal">
                    <Button Content="🌐  Open in Browser" Style="{StaticResource SecondaryButton}"
                            Padding="12,7" Click="OpenBrowser_Click"/>
                    <TextBlock Margin="14,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">
                        Recommended size: 400 × 120 px
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ══════ STATUS BAR ══════ -->
        <Border Grid.Row="5" Background="#0D0D15" CornerRadius="8" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusBar" Style="{StaticResource StatusText}" Text="Starting servers…" TextWrapping="Wrap"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="WS clients:" Style="{StaticResource StatusText}" Margin="0,0,4,0"/>
                    <TextBlock x:Name="WsClientCount" Text="0" Style="{StaticResource StatusText}" Foreground="{StaticResource AccentRedBrush}" FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
